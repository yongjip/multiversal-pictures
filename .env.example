OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AGENT_MODEL=gpt-5-mini
OPENAI_AGENT_REASONING_EFFORT=low
OPENAI_AGENT_TIMEOUT_SECONDS=600
OPENAI_VIDEO_MODEL=sora-2-pro
OPENAI_VIDEO_SIZE=1280x720
OPENAI_VIDEO_SECONDS=8
OPENAI_POLL_INTERVAL_SECONDS=10
OPENAI_VIDEO_TIMEOUT_SECONDS=1800
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_RESPONSE_FORMAT=wav
OPENAI_TTS_TIMEOUT_SECONDS=600
STORYBOOK_NARRATION_OFFSET_MS=500
STORYBOOK_CLIP_AUDIO_VOLUME=0.0
STORYBOOK_NARRATION_VOLUME=1.0
STORYBOOK_MUSIC_VOLUME=0.12
STORYBOOK_DUCK_MUSIC_UNDER_NARRATION=1
